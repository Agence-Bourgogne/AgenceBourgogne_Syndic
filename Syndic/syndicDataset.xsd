					<TableAdapter BaseClass="System.ComponentModel.Component"
					              DataAccessorModifier="AutoLayout, AnsiClass, Class, Public"
					              DataAccessorName="facturation_descrTableAdapter"
					              GeneratorDataComponentClassName="facturation_descrTableAdapter" Name="facturation_descr"
					              UserDataComponentName="facturation_descrTableAdapter">
						<MainSource>
							<DbSource ConnectionRef="syndicConnectionStringODBC (Settings)" DbObjectType="Unknown"
							          FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false"
							          GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public"
							          GetMethodName="GetData" QueryType="Rowset"
							          ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
							          UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
								<SelectCommand>
									<DbCommand CommandType="Text" ModifiedByUser="true">
										<CommandText>
											Select
											i.reference as immeuble,
											e.date_reference ,   n.reference as nature,
											e.base_repart,
											f.reference as num_fournisseur,
											f.nom as fournisseur,
											e.libelle,
											e.montant,
											e.comment_fournisseur

											from agence.saisie_facture e
											left join agence.immeuble i on i.id = e.immeuble_id
											left join agence.fournisseur f on f.id = e.fournisseur_id
											left join agence.nature n on n.id = e.nature_id
										</CommandText>
										<Parameters />
									</DbCommand>
								</SelectCommand>
							</DbSource>
						</MainSource>
						<Mappings>
							<Mapping SourceColumn="immeuble" DataSetColumn="immeuble" />
							<Mapping SourceColumn="date_reference" DataSetColumn="date_reference" />
							<Mapping SourceColumn="nature" DataSetColumn="nature" />
							<Mapping SourceColumn="base_repart" DataSetColumn="base_repart" />
							<Mapping SourceColumn="num_fournisseur" DataSetColumn="num_fournisseur" />
							<Mapping SourceColumn="fournisseur" DataSetColumn="fournisseur" />
							<Mapping SourceColumn="libelle" DataSetColumn="libelle" />
							<Mapping SourceColumn="montant" DataSetColumn="montant" />
							<Mapping SourceColumn="comment_fournisseur" DataSetColumn="comment_fournisseur" />
						</Mappings>
						<Sources />
					</TableAdapter>
