					              GeneratorDataComponentClassName="facturation_hdr_descrTableAdapter" Name="facturation_hdr_descr"
					              UserDataComponentName="facturation_hdr_descrTableAdapter">
						<MainSource>
							<DbSource ConnectionRef="syndicConnectionStringODBC (Settings)"
							          DbObjectName="SELECT groupe, nom, iparam_1 FROM &quot;public&quot;.parametres WHERE (groupe = 'FACTURE_REGLEMENT')"
							          DbObjectType="Unknown" FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both"
							          GenerateShortCommands="false" GeneratorGetMethodName="GetData" GeneratorSourceName="Fill"
							          GetMethodModifier="Public" GetMethodName="GetData" QueryType="Rowset"
							          ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
							          UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
								<SelectCommand>
									<DbCommand CommandType="Text" ModifiedByUser="true">
										<CommandText>
											SELECT     p.nom, p.iparam_1 AS code, 'xx' AS reference, 'yy' AS nom_four
											FROM         agence.saisie_facture f,
											(SELECT     groupe, nom, iparam_1
											FROM          "public".parametres
											WHERE      (groupe = 'FACTURE_REGLEMENT')) p
											WHERE     f.reglement = p.iparam_1
										</CommandText>
										<Parameters />
									</DbCommand>
								</SelectCommand>
