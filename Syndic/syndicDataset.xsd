					<TableAdapter BaseClass="System.ComponentModel.Component"
					              DataAccessorModifier="AutoLayout, AnsiClass, Class, Public"
					              DataAccessorName="CompteGestionGeneralTableAdapter"
					              GeneratorDataComponentClassName="CompteGestionGeneralTableAdapter" Name="CompteGestionGeneral"
					              UserDataComponentName="CompteGestionGeneralTableAdapter">
						<MainSource>
							<DbSource ConnectionRef="syndicConnectionStringODBC (Settings)" DbObjectType="Unknown"
							          FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false"
							          GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public"
							          GetMethodName="GetData" QueryType="Rowset"
							          ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
							          UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
								<SelectCommand>
									<DbCommand CommandType="Text" ModifiedByUser="true">
										<CommandText>
											SELECT     n.reference, n.nom AS nature, f.nom AS fournisseur, sf.libelle, sf.date_reference, sf.base_repart, CASE WHEN sf.montant &gt; 0 THEN sf.montant ELSE 0 END AS debit,
											CASE WHEN sf.montant &lt; 0 THEN sf.montant * - 1 ELSE 0 END AS credit
											FROM         agence.saisie_facture sf, agence.nature n, agence.fournisseur f
											WHERE     sf.nature_id = n.id AND sf.fournisseur_id = f.id AND (sf.immeuble_id = '0')
											ORDER BY 1, sf.date_reference
										</CommandText>
										<Parameters />
									</DbCommand>
								</SelectCommand>
							</DbSource>
						</MainSource>
						<Mappings>
							<Mapping SourceColumn="reference" DataSetColumn="reference" />
							<Mapping SourceColumn="nature" DataSetColumn="nature" />
							<Mapping SourceColumn="fournisseur" DataSetColumn="fournisseur" />
							<Mapping SourceColumn="libelle" DataSetColumn="libelle" />
							<Mapping SourceColumn="date_reference" DataSetColumn="date_reference" />
							<Mapping SourceColumn="base_repart" DataSetColumn="base_repart" />
							<Mapping SourceColumn="debit" DataSetColumn="debit" />
							<Mapping SourceColumn="credit" DataSetColumn="credit" />
						</Mappings>
						<Sources />
					</TableAdapter>
					<TableAdapter BaseClass="System.ComponentModel.Component"
					              DataAccessorModifier="AutoLayout, AnsiClass, Class, Public"
					              DataAccessorName="BilanOperationsCoproprietairesTableAdapter"
					              GeneratorDataComponentClassName="BilanOperationsCoproprietairesTableAdapter"
					              Name="BilanOperationsCoproprietaires"
					              UserDataComponentName="BilanOperationsCoproprietairesTableAdapter">
						<MainSource>
							<DbSource ConnectionRef="syndicConnectionStringODBC (Settings)" DbObjectType="Unknown"
							          FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false"
							          GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public"
							          GetMethodName="GetData" QueryType="Rowset"
							          ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
							          UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
								<SelectCommand>
									<DbCommand CommandType="Text" ModifiedByUser="true">
										<CommandText>
											SELECT     lot_description.numero_lot, CONCAT(coproprietaire.nom, ' ', coproprietaire.prenom) AS nom, operation.libelle, operation.base_repart, operation.debit, operation.credit,
											nature.reference, CASE WHEN nature.reference = '140' THEN 0 ELSE operation.debit END AS debit_no_solde,
											CASE WHEN nature.reference = '140' THEN 0 ELSE operation.credit END AS credit_no_solde
											FROM         agence.immeuble, agence.coproprietaire, agence.operation, agence.lot_description, agence.nature
											WHERE     (operation.lot_id = lot_description.id) AND (operation.coproprietaire_id = coproprietaire.id) AND (operation.nature_id = nature.id) AND
											(operation.immeuble_id = immeuble.id) AND (operation.immeuble_id = '194A4A27717447B1855A5DCEA573C878') AND (agence.operation.type_mouvement = 'Recette')
											AND (nature.reference &lt;&gt; '145')
											ORDER BY nature.reference, coproprietaire.reference, operation.date_reference
										</CommandText>
										<Parameters />
									</DbCommand>
								</SelectCommand>
							</DbSource>
						</MainSource>
						<Mappings>
							<Mapping SourceColumn="numero_lot" DataSetColumn="numero_lot" />
							<Mapping SourceColumn="nom" DataSetColumn="nom" />
							<Mapping SourceColumn="libelle" DataSetColumn="libelle" />
							<Mapping SourceColumn="base_repart" DataSetColumn="base_repart" />
							<Mapping SourceColumn="debit" DataSetColumn="debit" />
							<Mapping SourceColumn="credit" DataSetColumn="credit" />
							<Mapping SourceColumn="reference" DataSetColumn="reference" />
							<Mapping SourceColumn="debit_no_solde" DataSetColumn="debit_no_solde" />
							<Mapping SourceColumn="credit_no_solde" DataSetColumn="credit_no_solde" />
						</Mappings>
						<Sources />
