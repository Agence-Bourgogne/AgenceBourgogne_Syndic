                <TablixCell>
                  <CellContents>
                    <Textbox Name="global">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>=IIF(Fields!global.Value &lt;&gt; 0, Fields!global.Value, "")</Value>
                              <Style>
