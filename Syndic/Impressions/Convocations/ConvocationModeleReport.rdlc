      <Textbox Name="Textbox4">
        <CanGrow>true</CanGrow>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>="L'an "+Parameters!AnneeAssemblee.Value+ ", le "+Parameters!DateAssembleeText.Value+ " à "+Parameters!HeureAssemblee.Value+ ", Mesdames et Messieurs, les copropriétaires de l'immeuble situé "+Parameters!AdresseImmeuble.Value+ " ont été régulièrement convoqués par lettres recommandées pour assister à l'assemblée générale "+Variables!convoc.Value+" qui se tiendra " + Parameters!LieuAssemblee.Value</Value>
                <Style />
              </TextRun>
            </TextRuns>
            <Style />
          </Paragraph>
        </Paragraphs>
