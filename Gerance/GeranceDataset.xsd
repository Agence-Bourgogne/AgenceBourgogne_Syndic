                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT     b.reference AS b_reference, b.nom AS b_nom, b.numero_lot, r.date_reglement, '020' AS nature, r.base_honoraire, p.taux_honoraire, r.tire, 
                      ROUND(r.base_honoraire * p.taux_honoraire / 100, 2) AS honoraire, ROUND(r.base_honoraire * p.taux_honoraire / 100 * 0.2, 2) AS tva_debit_hono, r.frais_bail, r.etat_lieux, 
