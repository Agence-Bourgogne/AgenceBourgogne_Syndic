          <TableAdapter BaseClass="System.ComponentModel.Component" DataAccessorModifier="AutoLayout, AnsiClass, Class, Public" DataAccessorName="releve_honoraire_proprioTableAdapter" GeneratorDataComponentClassName="releve_honoraire_proprioTableAdapter" Name="releve_honoraire_proprio" UserDataComponentName="releve_honoraire_proprioTableAdapter">
