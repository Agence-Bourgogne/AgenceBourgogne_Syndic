          <TableAdapter BaseClass="System.ComponentModel.Component" DataAccessorModifier="AutoLayout, AnsiClass, Class, Public" DataAccessorName="QuittanceLoyerLocataireTableAdapter" GeneratorDataComponentClassName="QuittanceLoyerLocataireTableAdapter" Name="QuittanceLoyerLocataire" UserDataComponentName="QuittanceLoyerLocataireTableAdapter">
