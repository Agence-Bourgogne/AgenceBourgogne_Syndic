              <DbSource ConnectionRef="geranceConnectionString (Settings)" DbObjectType="Unknown" FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false" GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public" GetMethodName="GetData" QueryType="Rowset" ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT     b.montant_loyer, b.montant_augmentation, b.valeur_taxe, b.montant_charges, b.frais_bail, 0.00 AS etat_lieux, l.total_du - b.montant_du AS reste_du, 
                      b.honoraires_locataire, 
                      b.montant_loyer + b.montant_augmentation + b.valeur_taxe + b.montant_charges + b.frais_bail + l.total_du - b.montant_du + b.montant_divers1 + b.montant_divers2 + b.montant_divers3
                       + b.montant_divers4 + b.montant_divers5 AS total_du, b.montant_divers1, b.montant_divers2, b.montant_divers3, b.montant_divers4, b.montant_divers5, b.divers1, 
                      b.divers2, b.divers3, b.divers4, b.divers5, CONCAT(l.nom, ' ', l.prenom) AS nom_loca, l.adresse, l.ville, l.codepostal, l.reference, b.adresse AS imm_adress, 
                      b.ville AS imm_ville, b.codepostal AS imm_cp, b.periodicite_loyer
FROM         agence.biens b, agence.locataire l
WHERE     b.locataire_id = l.id AND (l.reference = 'VOL770')</CommandText>
